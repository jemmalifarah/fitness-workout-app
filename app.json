{
  "expo": {
    "name": "Fitness Workout App",
    "slug": "fitness-workout-app",
    "version": "1.0.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-status-bar",
        {
          "backgroundColor": "#ffffff"
        }
      ]
    ]
  }
}
